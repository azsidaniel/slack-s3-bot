SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-level-token

S3_BUCKET=your-s3-bucket-name
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
GOOGLE_DRIVE_API_KEY=your-google-drive-api-key

# Defaults match the current static infographic deploy behavior.
S3_CACHE_CONTROL=public,max-age=60
S3_ACL=public-read

# Optional local safety switch. Use false only if you want to test parsing.
ALLOW_UPLOAD=true

# Use local for development or s3 for shared persistence in AWS.
PREFIX_STORE=local
PREFIX_STORE_S3_KEY=_bot/channel-prefixes.json
